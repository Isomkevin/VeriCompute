# Frontend (public) network config
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Deployed contracts (fill after `scripts/deploy-testnet.sh`)
NEXT_PUBLIC_VERIFIER_CONTRACT_ID=
NEXT_PUBLIC_ESCROW_CONTRACT_ID=

# Prover integration
# If set, `apps/web` will call this HTTP prover instead of running a local subprocess.
PROVER_SERVICE_URL=

# WSL repo path for local proving from Windows Next.js API
PROVER_WSL_REPO_PATH=/mnt/c/Users/Administrator/Downloads/VeriCompute

# Soroban token contract used by escrow (native XLM SAC on testnet — set after deploy/init)
NEXT_PUBLIC_TOKEN_CONTRACT_ID=

# Guest program identity (fill after building `zk/guest`)
GUEST_IMAGE_ID=

# Local-only secrets (never commit real values)
# DEPLOYER_SECRET=

